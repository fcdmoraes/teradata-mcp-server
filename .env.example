# =============================================================================
# Teradata MCP Server — variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores
# =============================================================================

# --- Conexão obrigatória ---
# Formato: teradata://usuario:senha@host:porta/database
DATABASE_URI=teradata://usuario:senha@host:1025/database

# --- Autenticação (opcional, padrão: TD2) ---
# TD2 = usuário/senha Teradata | LDAP = Active Directory
# LOGMECH=TD2

# --- Pool de conexões (opcional) ---
# TD_POOL_SIZE=5
# TD_MAX_OVERFLOW=10
# TD_POOL_TIMEOUT=30

# --- Transporte MCP (opcional, padrão: stdio) ---
# "stdio" para Claude Desktop | "streamable-http" para HTTP
# MCP_TRANSPORT=stdio
# MCP_HOST=localhost
# MCP_PORT=8001
# MCP_PATH=/mcp/

# --- Limites de resultado (opcional) ---
# DEFAULT_ROW_LIMIT=1000
# MAX_ROW_LIMIT=50000

# --- Logging (opcional, padrão: WARNING) ---
# LOGGING_LEVEL=WARNING
